# Kiris environment variables — sample file
# ---------------------------------------------------------------------------
# Copy to .env.local for local dev. NEVER commit a populated copy of this file.
# Production secrets live in AWS Secrets Manager and rotate quarterly (§6.4).
# ---------------------------------------------------------------------------

# ---- Marketing site (apps/marketing) ----
# Public, no PHI. Hosted on Vercel.
NEXT_PUBLIC_SITE_URL=https://kiris.ai
NEXT_PUBLIC_APP_URL=https://app.kiris.ai
NEXT_PUBLIC_DOCS_URL=https://docs.kiris.ai

# Analytics — privacy-respecting, no PHI ever
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=kiris.ai

# ---- App (apps/app) ----
# Authoring app. Tier-aware. Hosted on AWS.
NEXT_PUBLIC_API_URL=https://api.kiris.ai

# AWS Cognito (customer auth)
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_REGION=us-east-1

# ---- API (apps/api) ----
# Server-only. NEVER expose any of these in NEXT_PUBLIC_*.
NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# Postgres (RDS in production)
DATABASE_URL=postgres://kiris:dev@localhost:5432/kiris
DATABASE_READ_REPLICA_URL=

# AWS — service IAM role in production; access keys for local dev only
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# S3 buckets
S3_ASSETS_BUCKET=kiris-assets-dev
S3_EXPORTS_BUCKET=kiris-exports-dev
S3_HIPAA_PREFIX=hipaa/                 # HIPAA-scoped prefix; Phase 2

# KMS
KMS_KEY_ID_STANDARD=
KMS_KEY_ID_HIPAA=                      # one CMK per HIPAA tenant in production

# Anthropic — TWO keys: standard + BAA-covered (Phase 2)
# Server-side only. Routed by tenant.hipaa_enabled flag.
ANTHROPIC_API_KEY_STANDARD=
ANTHROPIC_API_KEY_HIPAA=
ANTHROPIC_MODEL=claude-sonnet-4-6

# AWS Polly + Comprehend Medical + Textract use AWS_REGION + IAM role.

# Stripe — never sees PHI
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe Price IDs (created out-of-band; mirrored to packages/billing config)
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_ANNUAL=
STRIPE_PRICE_TEAM_MONTHLY=
STRIPE_PRICE_TEAM_ANNUAL=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=

# Sentry — has BAA; PHI scrubbed before send
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ---- Admin console (apps/admin) ----
# Stricter perimeter. Google Workspace SSO + hardware key MFA mandatory.
GOOGLE_WORKSPACE_DOMAIN=kiris.ai
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
ADMIN_SESSION_SECRET=                  # 32+ random bytes; rotate quarterly

# ---- Shared ----
# Used for signing internal tokens, CSRF, etc. Rotate quarterly.
INTERNAL_SIGNING_KEY=
